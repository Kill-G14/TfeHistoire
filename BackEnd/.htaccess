# Configuration Apache pour le backend


# Bloquer l'accès aux fichiers sensibles
<FilesMatch "^(composer\.json|composer\.lock|\.gitignore)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Bloquer l'accès au dossier vendor
RedirectMatch 403 ^/vendor/.*$

# Headers de sécurité
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
</IfModule>

# Compression Gzip
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/json application/javascript
</IfModule>

# Cache
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType application/json "access plus 0 seconds"
</IfModule>
