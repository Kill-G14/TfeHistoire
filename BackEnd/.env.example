# ==============================================
# CONFIGURATION MEMORIAEVENTIA - PRODUCTION
# ==============================================
# 1. Copiez ce fichier en .env
# 2. Remplissez TOUTES les valeurs avec vos vraies données
# 3. Ne commitez JAMAIS le fichier .env dans Git !

# ==============================================
# ENVIRONNEMENT
# ==============================================
# Options : development, production
APP_ENV=production
APP_DEBUG=false
APP_NAME=MemoriaEventia

# ==============================================
# URLS
# ==============================================
# URL du frontend (sans slash final)
# Exemple: https://memoriaeventia.com
FRONTEND_URL=https://votre-domaine.com

# URL de l'API backend (sans slash final)
# Exemple: https://memoriaeventia.com/BackEnd/Api
API_URL=https://votre-domaine.com/BackEnd/Api

# Domaines autorisés pour CORS (séparés par des virgules)
# En production: votre domaine HTTPS uniquement
ALLOWED_ORIGINS=https://votre-domaine.com

# ==============================================
# BASE DE DONNÉES
# ==============================================
DB_HOST=localhost
DB_NAME=memoriaeventia
DB_USER=votre_user_mysql
DB_PASSWORD=votre_mot_de_passe_mysql
DB_CHARSET=utf8mb4

# ==============================================
# OPENROUTE SERVICE API
# ==============================================
# Obtenir une clé API sur : https://openrouteservice.org/dev/#/signup
OPENROUTE_API_KEY=votre_cle_api_openroute
OPENROUTE_BASE_URL=https://api.openrouteservice.org/v2

# ==============================================
# SÉCURITÉ
# ==============================================
# Durée de vie des sessions en jours
SESSION_LIFETIME_DAYS=14

# Nombre maximum de tentatives de connexion avant blocage
MAX_LOGIN_ATTEMPTS=5

# Durée du blocage après trop de tentatives (en minutes)
LOGIN_BLOCK_DURATION_MINUTES=15

# ==============================================
# SENDGRID - ENVOI D'EMAILS
# ==============================================
# Obtenir une clé API sur : https://app.sendgrid.com/settings/api_keys
# IMPORTANT : Configurer SPF et DKIM pour votre domaine
SENDGRID_API_KEY=votre_cle_api_sendgrid
SENDGRID_FROM_EMAIL=contact@votre-domaine.com
SENDGRID_FROM_NAME=MemoriaEventia
SENDGRID_ENABLED=true

# ==============================================
# LOGS
# ==============================================
LOG_PATH=../logs
LOG_LEVEL=info

# Durée du blocage en minutes après trop de tentatives
LOGIN_BLOCK_DURATION_MINUTES=15

# ==============================================
# SENDGRID - ENVOI D'EMAILS
# ==============================================
# Clé API SendGrid (à obtenir sur https://app.sendgrid.com/settings/api_keys)
SENDGRID_API_KEY=your_sendgrid_api_key_here

# Email d'expédition (doit être vérifié dans SendGrid)
SENDGRID_FROM_EMAIL=noreply@memoriaeventia.com

# Nom de l'expéditeur
SENDGRID_FROM_NAME=MemoriaEventia

# Activer/Désactiver l'envoi d'emails (true/false)
# Mettre à false en développement pour éviter d'envoyer des vrais emails
SENDGRID_ENABLED=false

# ==============================================
# LOGS
# ==============================================
# Emplacement des logs
LOG_PATH=../vendor/logs
LOG_LEVEL=debug
