# ==============================================
# CONFIGURATION MEMORIAEVENTIA - TEMPLATE
# ==============================================
# Copiez ce fichier en .env et remplissez avec vos vraies valeurs

# ==============================================
# ENVIRONNEMENT
# ==============================================
# Options : development, production
APP_ENV=development
APP_DEBUG=true
APP_NAME=MemoriaEventia

# ==============================================
# URLS
# ==============================================
# URL du frontend (sans slash final)
FRONTEND_URL=http://localhost/tfeHistoire

# URL de l'API backend (sans slash final)
API_URL=http://localhost/tfeHistoire/BackEnd/Api

# Domaines autorisés pour CORS (séparés par des virgules)
# En dev: http://localhost,http://127.0.0.1
# En prod: https://votre-domaine.com
ALLOWED_ORIGINS=http://localhost,http://127.0.0.1

# ==============================================
# BASE DE DONNÉES
# ==============================================
DB_HOST=localhost
DB_NAME=memoriaeventia
DB_USER=root
DB_PASSWORD=
DB_CHARSET=utf8mb4

# ==============================================
# OPENROUTE SERVICE API
# ==============================================
OPENROUTE_API_KEY=your_api_key_here
OPENROUTE_BASE_URL=https://api.openrouteservice.org/v2

# ==============================================
# SÉCURITÉ
# ==============================================
# Durée de vie des sessions en jours
SESSION_LIFETIME_DAYS=14

# Nombre maximum de tentatives de connexion avant blocage
MAX_LOGIN_ATTEMPTS=5

# Durée du blocage en minutes après trop de tentatives
LOGIN_BLOCK_DURATION_MINUTES=15

# ==============================================
# EMAIL (À configurer plus tard)
# ==============================================
# Options : smtp, sendgrid, mailgun, aws_ses
MAIL_DRIVER=smtp

MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=your_email@example.com
MAIL_PASSWORD=your_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@memoriaeventia.com
MAIL_FROM_NAME=MemoriaEventia

# ==============================================
# LOGS
# ==============================================
# Emplacement des logs
LOG_PATH=../vendor/logs
LOG_LEVEL=debug
